# Single source of truth for the LOCAL SurveyJS V3 build location.
#
# This is the absolute path to the parent folder that contains the
# `survey-library` and `survey-creator` repos (whose package build
# outputs the apps consume via `file:` dependencies).
#
# Copy this file to `.env` (committed default) or `.env.local`
# (per-machine, git-ignored) and adjust the path. Then run:
#
#   npm run sync:deps      # rewrite every app's survey-* paths from here
#   npm install            # (or: npm run install:all, which does both)
#
SURVEYJS_LIBV3=C:/survey.js/LibV3

# Dependency source selector for the survey-* packages:
#   true  (default) -> use the LOCAL `file:` builds at SURVEYJS_LIBV3 above.
#   false           -> use the published npm packages (a ^<version> range,
#                      read from the local build's version when present, else
#                      "*"). Run `npm run sync:deps && npm install` after
#                      changing this.
SurveyJS_LIB_USE_PATH=true

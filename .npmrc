# Keep a single React instance for the linked SurveyJS builds.
# Hoist react/react-dom to the top so linked packages resolve the app's copy.
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=react/*
public-hoist-pattern[]=react-dom/*
# Linked builds live outside the workspace; allow pnpm to follow them.
node-linker=hoisted

{
  "name": "@adapter/bootstrap",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "copy-themes": "node scripts/copy-themes.mjs",
    "copy-survey-adapters": "node scripts/copy-survey-adapters.mjs --dev",
    "watch-survey-adapters": "node scripts/copy-survey-adapters.mjs --dev --watch",
    "predev": "node scripts/copy-themes.mjs && node scripts/copy-survey-adapters.mjs --dev",
    "dev": "next dev -p 3000",
    "prebuild": "node scripts/copy-themes.mjs && node scripts/copy-survey-adapters.mjs",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf .next *.tsbuildinfo"
  },
  "dependencies": {
    "@adapter/schemas": "*",
    "bootstrap": "^5.3.3",
    "bootswatch": "^5.3.3",
    "react-bootstrap": "^2.10.5",
    "react-bootstrap-icons": "^1.11.6"
  }
}

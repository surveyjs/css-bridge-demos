{
  "name": "@bridge/schemas",
  "version": "0.0.0",
  "private": true,
  "description": "Single source of truth: SurveyJS V3 schemas, seed data, model factory, and shared IA. Depends on survey-core ONLY.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist *.tsbuildinfo",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "survey-core": "link:../../../survey-library/packages/survey-core/build"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
